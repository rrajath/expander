<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include shared preferences for backup -->
        <include domain="sharedpref" path="expander_prefs.xml"/>

        <!-- Include database for snippets backup -->
        <include domain="database" path="snippet_database"/>
    </cloud-backup>

    <device-transfer>
        <!-- Include shared preferences for device transfer -->
        <include domain="sharedpref" path="expander_prefs.xml"/>

        <!-- Include database for snippets transfer -->
        <include domain="database" path="snippet_database"/>
    </device-transfer>
</data-extraction-rules>